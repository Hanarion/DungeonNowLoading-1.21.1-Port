{
  "multipart": [
    { "when": { "shape": "ascending_east" }, "apply": { "model": "minecraft:block/rail_raised_ne", "y": 90 } },
    { "when": { "shape": "ascending_north" }, "apply": { "model": "minecraft:block/rail_raised_ne" } },
    { "when": { "shape": "ascending_south" }, "apply": { "model": "minecraft:block/rail_raised_sw" } },
    { "when": { "shape": "ascending_west" }, "apply": { "model": "minecraft:block/rail_raised_sw", "y": 90 } },
    { "when": { "shape": "east_west" }, "apply": { "model": "minecraft:block/rail", "y": 90 } },
    { "when": { "shape": "north_south" }, "apply": { "model": "minecraft:block/rail" } },
    { "when": { "shape": "north_east" }, "apply": { "model": "minecraft:block/rail_corner", "y": 270 } },
    { "when": { "shape": "north_west" }, "apply": { "model": "minecraft:block/rail_corner", "y": 180 } },
    { "when": { "shape": "south_east" }, "apply": { "model": "minecraft:block/rail_corner" } },
