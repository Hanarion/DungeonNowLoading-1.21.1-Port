    { "when": { "shape": "ascending_east", "signal": "1" }, "apply": { "model": "dungeonnowloading:block/signal_rail_left_on_raised_ne", "y": 90 } },
    { "when": { "shape": "ascending_east", "signal": "2" }, "apply": { "model": "dungeonnowloading:block/signal_rail_right_on_raised_ne", "y": 90 } },
    { "when": { "shape": "ascending_north", "signal": "0" }, "apply": { "model": "dungeonnowloading:block/signal_rail_raised_ne" } },
    { "when": { "shape": "ascending_north", "signal": "1" }, "apply": { "model": "dungeonnowloading:block/signal_rail_left_on_raised_ne" } },
    { "when": { "shape": "ascending_north", "signal": "2" }, "apply": { "model": "dungeonnowloading:block/signal_rail_right_on_raised_ne" } },
    { "when": { "shape": "ascending_south", "signal": "0" }, "apply": { "model": "dungeonnowloading:block/signal_rail_raised_sw" } },
    { "when": { "shape": "ascending_south", "signal": "1" }, "apply": { "model": "dungeonnowloading:block/signal_rail_left_on_raised_sw" } },
    { "when": { "shape": "ascending_south", "signal": "2" }, "apply": { "model": "dungeonnowloading:block/signal_rail_right_on_raised_sw" } },
    { "when": { "shape": "ascending_west", "signal": "0" }, "apply": { "model": "dungeonnowloading:block/signal_rail_raised_sw", "y": 90 } },
    { "when": { "shape": "ascending_west", "signal": "1" }, "apply": { "model": "dungeonnowloading:block/signal_rail_left_on_raised_sw", "y": 90 } },
    { "when": { "shape": "ascending_west", "signal": "2" }, "apply": { "model": "dungeonnowloading:block/signal_rail_right_on_raised_sw", "y": 90 } },
    { "when": { "shape": "east_west", "signal": "0" }, "apply": { "model": "dungeonnowloading:block/signal_rail", "y": 90 } },
    { "when": { "shape": "east_west", "signal": "1" }, "apply": { "model": "dungeonnowloading:block/signal_rail_left_on", "y": 90 } },
    { "when": { "shape": "east_west", "signal": "2" }, "apply": { "model": "dungeonnowloading:block/signal_rail_right_on", "y": 90 } },
    { "when": { "shape": "north_south", "signal": "0" }, "apply": { "model": "dungeonnowloading:block/signal_rail" } },
    { "when": { "shape": "north_south", "signal": "1" }, "apply": { "model": "dungeonnowloading:block/signal_rail_left_on" } },
    { "when": { "shape": "north_south", "signal": "2" }, "apply": { "model": "dungeonnowloading:block/signal_rail_right_on" } },
    { "when": { "shape": "ascending_south" }, "apply": { "model": "dungeonnowloading:block/deepsteel_slope" } },
    { "when": { "shape": "ascending_west" }, "apply": { "model": "dungeonnowloading:block/deepsteel_slope", "y": 90 } },
    { "when": { "shape": "ascending_north" }, "apply": { "model": "dungeonnowloading:block/deepsteel_slope", "y": 180 } },
    { "when": { "shape": "ascending_east" }, "apply": { "model": "dungeonnowloading:block/deepsteel_slope", "y": 270 } }
